<!DOCTYPE html>
<html>
  <head>
    <title>Order Confirmation - MyShop</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      body {
        margin: 0;
        padding: 0;
        background-color: #f9fafb;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: #111827;
      }

      .container {
        max-width: 600px;
        margin: 0 auto;
        background: #ffffff;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.04);
      }

      .header {
        background-color: cadetblue;
        padding: 20px;
        text-align: center;
        color: #fff;
      }

      .header h1 {
        margin: 0;
        font-size: 24px;
        font-weight: 600;
      }

      .body {
        padding: 30px;
      }

      body h2 {
        margin-top: 0;
        font-size: 20px;
        color: #111827;
      }

      .order-summary {
        background-color: #f3f4f6;
        padding: 15px;
        border-radius: 6px;
        margin-top: 20px;
        font-size: 14px;
      }

      .order-summary p {
        margin: 6px 0;
        line-height: 1.5;
      }

      .total {
        font-weight: bold;
        font-size: 16px;
        margin-top: 10px;
      }

      .button {
        display: inline-block;
        background-color: #2563eb;
        color: #ffffff;
        padding: 12px 20px;
        margin-top: 30px;
        text-decoration: none;
        border-radius: 5px;
        font-weight: bold;
      }

      .footer {
        padding: 20px;
        font-size: 12px;
        text-align: center;
        color: #111827;
        background-color: #f9fafb;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <h1>Order Confirmation</h1>
      </div>
      <div class="body">
        <h2>Thank you for your order! <%=name%></h2>
        <p>
          Your order has been successfully placed. We will notify you via email
          once your order has been shipped.
        </p>
        <div class="order-summary">
          <% cart.forEach(item=>{ %>
          <p>
            <strong><%=item.title%></strong> - <%=item.quantity%> x
            <%=item.sale_price%> = <%=item.quantity * item.sale_price%>
          </p>
          <% }) %>
          <a href="<%=orderTrackingUrl%>" class="button">Track Order</a>

          <p style="margin-top: 10px">Order ID: <%=orderId%></p>

          <p style="margin-top: 10px">
            If you have any questions, please contact us at
          </p>
          <p style="margin-top: 10px">support@myshop.com</p>
        </div>
        <p>Thank you for shopping with us!</p>
      </div>
      <div class="footer">
        <p>MyShop</p>
        <p>123 Main St</p>
        <p>Anytown, USA</p>
      </div>
    </div>
  </body>
</html>
