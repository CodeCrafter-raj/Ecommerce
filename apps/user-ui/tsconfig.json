{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "module": "esnext",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "noEmit": true, // ⭐ REQUIRED FOR NEXT.JS
    "allowImportingTsExtensions": true, // works now
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "types": [
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@packages/*": [
        "../../packages/*"
      ],
      "@packages/libs/*": [
        "../../packages/libs/*"
      ],
      "@packages/utils/*": [
        "../../packages/utils/*"
      ],
      "@packages/error-handler/*": [
        "../../packages/error-handler/*"
      ],
      "@middleware/*": [
        "../../packages/middleware/*"
      ]
    },
    "allowJs": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".next"
  ]
}
