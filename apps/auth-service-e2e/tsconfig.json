{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "out-tsc/@myshop/auth-service-e2e",
    "esModuleInterop": true,
    "noUnusedLocals": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "types": [
      "node",
      "jest"
    ],
    "typeRoots": [
      "../../node_modules/@types",
      "./node_modules/@types"
    ]
  },
  "include": [
    "jest.config.ts",
    "src", // <-- includes .ts and .d.ts files now
    "**/*.d.ts"
  ],
  "references": []
}
