{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../../dist/apps/auth-service",
    "rootDir": "../../", 
    "composite": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmitOnError": false,
    "resolveJsonModule": true,
    "allowArbitraryExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@packages/*": ["../../packages/*"]
    }
  },
  "include": [
    "src/**/*",
    "../../packages/**/*",
    "src/**/*.json"
  ],
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "../../packages/libs/prisma" },
    { "path": "../../packages/libs/reddis" },
    { "path": "../../packages/error-handler" }
  ]
}
