{
  "name": "@myshop/auth-service",
  "version": "0.0.1",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "auth-docs": "node src/swagger.js",
    "generate-swagger-if-needed": "node scripts/generate-swagger-if-needed.cjs",
    "copy-swagger": "node copy-swagger.cjs",
    "copy-email-templates": "node copy-email-templates.cjs",
    "prebuild": "npm run generate-swagger-if-needed",
    "build": "webpack-cli build --node-env=production && npm run copy-swagger && npm run copy-email-templates",
    "dev": "npm run generate-swagger-if-needed && npm run copy-swagger &&  npm run copy-email-templates ts-node src/main.ts"
  },
  "nx": {
    "name": "@myshop/auth-service",
    "projectType": "application",
    "sourceRoot": "apps/auth-service/src",
    "targets": {
      "copy-swagger": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "apps/auth-service",
          "command": "node copy-swagger.cjs"
        }
      },
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "apps/auth-service",
          "command": "webpack-cli build --node-env=production"
        },
        "outputs": [
          "{workspaceRoot}/apps/auth-service/dist"
        ],
        "dependsOn": [
          "copy-swagger"
        ]
      },
      "serve": {
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build"
        ],
        "options": {
          "buildTarget": "@myshop/auth-service:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {
            "buildTarget": "@myshop/auth-service:build:development"
          },
          "production": {
            "buildTarget": "@myshop/auth-service:build:production"
          }
        }
      },
      "test": {
        "options": {
          "passWithNoTests": true
        }
      }
    }
  },
  "devDependencies": {
    "webpack-cli": "^6.0.1"
  }
}
