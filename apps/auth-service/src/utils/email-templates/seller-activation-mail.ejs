<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Start Your Eshop Seller Journey</title>
    <meta http-equiv="Content-Type" content="text/html;charset=UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style type="text/css">
      /* Base: kept for general body styling/modern clients, but inline is safer */
      body {
        padding: 0;
        min-width: 100%;
        font-family: Arial, sans-serif;
        font-size: 16px;
        line-height: 1.5;
        background-color: #f0f4f8; /* Slightly lighter, modern background */
        color: #222222;
      }

      /* Styles for media queries would go here for responsive design */
    </style>
  </head>

  <body
    style="
      padding: 0;
      min-width: 100%;
      font-family: Arial, sans-serif;
      font-size: 16px;
      line-height: 1.5;
      background-color: #f0f4f8;
      color: #222222;
      margin: 0;
      padding: 0;
    "
  >
    <table
      border="0"
      cellpadding="0"
      cellspacing="0"
      width="100%"
      style="margin: 0; padding: 0; background-color: #f0f4f8"
    >
      <tr>
        <td align="center">
          <table
            border="0"
            cellpadding="0"
            cellspacing="0"
            width="600"
            style="max-width: 600px; width: 100%"
          >
            <!-- Header Section -->
            <tr>
              <td
                align="center"
                style="
                  background-color: #004d99;
                  padding: 30px 24px;
                  color: #ffffff;
                  border-radius: 8px 8px 0 0;
                "
              >
                <h1
                  style="
                    font-size: 28px;
                    font-weight: 700;
                    line-height: 1.25;
                    margin-top: 0;
                    margin-bottom: 0;
                    text-align: center;
                    color: #ffffff;
                  "
                >
                  Welcome to the Myshop Seller Program!
                </h1>
              </td>
            </tr>

            <!-- Content Section -->
            <tr>
              <td style="padding: 24px; background-color: #ffffff">
                <p
                  style="
                    margin-top: 0;
                    margin-bottom: 24px;
                    font-size: 18px;
                    font-weight: bold;
                  "
                >
                  Hello <%= name %>,
                </p>
                <p style="margin-top: 0; margin-bottom: 24px">
                  Congratulations! We're excited to have you join the Eshop
                  seller community. We look forward to partnering with you to
                  grow your business.
                </p>
                <p style="margin-top: 0; margin-bottom: 24px">
                  To **activate your seller dashboard** and complete the final
                  step of your registration, please use the following one-time
                  activation code:
                </p>

                <!-- OTP Code Block -->
                <table border="0" cellpadding="0" cellspacing="0" width="100%">
                  <tr>
                    <td
                      align="center"
                      style="
                        padding: 15px 0;
                        background-color: #e6f0ff;
                        border-radius: 6px;
                      "
                    >
                      <h2
                        style="
                          font-size: 36px;
                          font-weight: 700;
                          margin-top: 0;
                          margin-bottom: 0;
                          color: #0070f3;
                          letter-spacing: 5px;
                        "
                      >
                        <%= otp %>
                      </h2>
                    </td>
                  </tr>
                </table>

                <p style="margin-top: 24px; margin-bottom: 24px">
                  Please enter this code on the activation page within the next
                  5 minutes to unlock your dashboard and start listing products.
                </p>
                <p
                  style="
                    margin-top: 0;
                    margin-bottom: 0;
                    font-style: italic;
                    color: #555555;
                  "
                >
                  If you did not initiate a seller registration for Eshop,
                  please disregard this email.
                </p>
              </td>
            </tr>

            <!-- Footer Section -->
            <tr>
              <td
                style="
                  background-color: #e0e0e0;
                  padding: 24px;
                  color: #222222;
                  border-radius: 0 0 8px 8px;
                "
              >
                <p style="margin-top: 0; margin-bottom: 8px; font-weight: bold">
                  Happy Selling,
                </p>
                <p style="margin-top: 0; margin-bottom: 0; font-size: 14px">
                  For any immediate questions about the onboarding process,
                  please contact our Seller Support Team at
                  <a
                    href="mailto:rs8260049@gmail.com"
                    style="color: #004d99; text-decoration: underline"
                    >Myshop.com Support</a
                  >.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
