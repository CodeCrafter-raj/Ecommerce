<!DOCTYPE html>
<html lang="en">

<head>
  <title>Eshop Activation Email</title>
  <meta http-equiv="Content-Type" content="text/html;charset=UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style type="text/css">
    /* Base: kept for general body styling/modern clients, but inline is safer */
    body {
      padding: 0;
      min-width: 100%;
      font-family: Arial, sans-serif;
      font-size: 16px;
      line-height: 1.5;
      background-color: #fafafa;
      color: #222222;
    }

    /* Styles for media queries would go here for responsive design */
  </style>
</head>

<body
  style="padding: 0; min-width: 100%; font-family: Arial, sans-serif; font-size: 16px; line-height: 1.5; background-color: #fafafa; color: #222222; margin: 0; padding: 0;">

  <table border="0" cellpadding="0" cellspacing="0" width="100%"
    style="margin: 0; padding: 0; background-color: #fafafa;">
    <tr>
      <td align="center">
        <table border="0" cellpadding="0" cellspacing="0" width="600" style="max-width: 600px; width: 100%;">

          <tr>
            <td align="center" style="background-color: #0070f3; padding: 24px; color: #ffffff;">
              <h1
                style="font-size: 24px; font-weight: 700; line-height: 1.25; margin-top: 0; margin-bottom: 0; text-align: center; color: #ffffff;">
                Welcome to Eshop</h1>
            </td>
          </tr>

          <tr>
            <td style="padding: 24px; background-color: #ffffff;">
              <p style="margin-top: 0; margin-bottom: 24px;">Hello <%= name %>,</p>
              <p style="margin-top: 0; margin-bottom: 24px;">
                Thank you for registering with Eshop. To activate your account, please
                use the following activation code:
              </p>
              <table border="0" cellpadding="0" cellspacing="0" width="100%">
                <tr>
                  <td align="center" style="padding: 10px 0;">
                    <h2 style="font-size: 30px; font-weight: 700; margin-top: 0; margin-bottom: 0; color: #0070f3;">
                      <%= otp %>
                    </h2>
                  </td>
                </tr>
              </table>

              <p style="margin-top: 24px; margin-bottom: 24px;"> Please enter this code on the activation page within
                the next 5 minutes.</p>
              <p style="margin-top: 0; margin-bottom: 0;">If you did not register for an Eshop account, please ignore
                this email.</p>
            </td>
          </tr>

          <tr>
            <td style="background-color: #f6f6f6; padding: 24px; color: #222222;">
              <p style="margin-top: 0; margin-bottom: 0;">
                If you have any questions, please don't hesitate to contact us at
                <a href="mailto:rs8260049@gmail.com" style="color: #000000; text-decoration: underline;">Myshop.com</a>
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

</body>

</html>