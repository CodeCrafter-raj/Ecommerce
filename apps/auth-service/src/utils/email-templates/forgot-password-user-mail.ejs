<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" lang="en">

<head>
    <title>My-Shop Password Reset Request</title>
    <meta http-equiv="Content-Type" content="text/html;charset=UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <!-- Global CSS for modern clients/basic typography control -->
    <style type="text/css">
        body {
            margin: 0;
            padding: 0;
            min-width: 100%;
            font-family: 'Arial', sans-serif;
            font-size: 16px;
            line-height: 1.6;
            background-color: #f4f4f4;
            color: #333333;
        }

        /* Responsive table for mobile optimization */
        .content {
            width: 100%;
            max-width: 600px;
            margin: 0 auto;
        }

        /* OTP box styling */
        .otp-box {
            background-color: #e9ecef;
            padding: 15px 25px;
            margin: 20px 0;
            border-radius: 6px;
            text-align: center;
        }
    </style>
</head>

<body style="margin: 0; padding: 0; min-width: 100%; background-color: #f4f4f4;">
    <!-- Main Wrapper Table (Ensures email is centered and takes full width on small screens) -->
    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #f4f4f4;">
        <tr>
            <td style="padding: 20px 0;">
                <!-- Content Table (The actual white container) -->
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" align="center" width="600" style="margin: 0 auto; background-color: #ffffff; border-radius: 8px; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);" class="content">
                    
                    <!-- Header/Logo Section -->
                    <tr>
                        <td align="center" style="padding: 20px 40px; border-bottom: 1px solid #eeeeee;">
                            <h1 style="margin: 0; font-size: 24px; color: #007bff;">My-Shop Password Reset</h1>
                        </td>
                    </tr>

                    <!-- Body Content -->
                    <tr>
                        <td style="padding: 40px; text-align: left; color: #333333;">
                            <p style="margin-top: 0; font-size: 16px;">Hello <%= name %>,</p>

                            <p style="font-size: 16px;">We received a request to reset the password for your My-Shop account. If you initiated this request, please use the button below to complete the process:</p>

                            <!-- Button Container (Must be a nested table for reliable centering/padding) -->
                            <table role="presentation" cellspacing="0" cellpadding="0" border="0" align="center" style="margin: 25px auto;">
                                <tr>
                                    <td align="center" style="border-radius: 4px; background-color: #007bff;">
                                        <a href="<%= reset_link %>" target="_blank" style="display: inline-block; padding: 12px 25px; font-size: 16px; color: #ffffff; text-decoration: none; border-radius: 4px; font-weight: bold; border: 1px solid #007bff;">
                                            Reset My Password
                                        </a>
                                    </td>
                                </tr>
                            </table>

                            <p style="font-size: 16px; text-align: center; margin-bottom: 30px;">
                                (If the button above does not work, you can also use this OTP below on the reset page.)
                            </p>
                            
                            <!-- OTP Box -->
                            <div class="otp-box" style="background-color: #f8f9fa; padding: 15px 25px; margin: 20px 0; border-radius: 6px; text-align: center; border: 1px dashed #ced4da;">
                                <p style="margin: 0; font-size: 14px; color: #6c757d;">Your One-Time Password (OTP)</p>
                                <h2 style="margin: 5px 0 0 0; font-size: 32px; color: #333333; letter-spacing: 2px;"><%= otp %></h2>
                            </div>

                            <p style="font-size: 16px; margin-top: 30px; font-weight: bold; color: #dc3545;">
                                This link/OTP is valid for the next 5 minutes only.
                            </p>

                            <p style="font-size: 16px; color: #6c757d;">
                                **Security Alert:** If you did not request this password reset, please ignore this email. Your password will remain unchanged.
                            </p>
                        </td>
                    </tr>

                    <!-- Footer Section -->
                    <tr>
                        <td align="center" style="padding: 20px 40px; font-size: 14px; color: #999999; border-top: 1px solid #eeeeee;">
                            <p style="margin: 0;">&copy; <%= new Date().getFullYear() %> My-Shop. All rights reserved.</p>
                            <p style="margin: 10px 0 0 0;">
                                Questions? Please contact us at 
                                <a href="mailto:support@Myshop.com" style="color: #007bff; text-decoration: none;">support@Myshop.com</a>
                            </p>
                        </td>
                    </tr>

                </table>
                <!-- End Content Table -->
            </td>
        </tr>
    </table>
    <!-- End Main Wrapper Table -->
</body>

</html>