{
  "name": "@myshop/api-gateway",
  "version": "0.0.1",
  "private": true,
  "nx": {
  "name": "@myshop/api-gateway",
  "projectType": "application",
  "sourceRoot": "apps/api-gateway/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/api-gateway",
        "command": "webpack-cli build --node-env=production"
      },
      "outputs": ["{workspaceRoot}/apps/api-gateway/dist"]
    },
    "prune-lockfile": {
      "dependsOn": ["build"],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/apps/api-gateway/dist/package.json",
        "{workspaceRoot}/apps/api-gateway/dist/package-lock.json"
      ],
      "options": {
        "buildTarget": "build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": ["build"],
      "cache": true,
      "outputs": [
        "{workspaceRoot}/apps/api-gateway/dist/workspace_modules"
      ],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "build"
      }
    },
    "prune": {
      "dependsOn": [
        "prune-lockfile",
        "copy-workspace-modules"
      ],
      "executor": "nx:noop"
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "@myshop/api-gateway:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "@myshop/api-gateway:build:development"
        },
        "production": {
          "buildTarget": "@myshop/api-gateway:build:production"
        }
      }
    }
  }
},
  "dependencies": {
    "express": "^4.21.2"
  }
}
