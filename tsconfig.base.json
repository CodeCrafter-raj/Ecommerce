{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@packages/*": [
        "packages/*"
      ],
      "@packages/libs/*": [
        "packages/libs/*"
      ],
      "@packages/utils/*": [
        "packages/utils/*"
      ],
      "@packages/error-handler/*": [
        "packages/error-handler/*"
      ],
      "@middleware/*": [
        "packages/middleware/*"
      ],
      "@components/*": [
        "packages/components/*"
      ]
    }
  },
  "include": [],
  "exclude": [
    "node_modules",
    "dist",
    "out-tsc"
  ]
}